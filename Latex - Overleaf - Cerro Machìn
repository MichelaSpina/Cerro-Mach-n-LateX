% SLIDE 4: DOMANDE DI RICERCA
\begin{frame}{Research Questionsb }
  \begin{block}{Fundamental Question}
    How does local vegetation respond to the combined thermal and geochemical stresses imposed by active degassing?
  \end{block}
  \begin{block} {}
  Can these interacting gradients act as ecological drivers capable of shaping functional trait expression and promoting divergent adaptive strategies within exposed plant communities?
  \end{block}
\end{frame}

