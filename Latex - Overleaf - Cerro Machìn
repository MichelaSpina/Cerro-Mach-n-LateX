% SLIDE 14: RESULTS - POLARIZATION
\begin{frame}{Results: Polarization of Adaptive Strategies}
  \begin{columns}[T]
    \begin{column}{0.48\textwidth}
      \textbf{\textcolor{red}{Orchidaceae (Avoidance Strategy)}}
      \begin{itemize}
        \item SD Reduction: $97.2 \rightarrow 48.7$ n/$mm^2$.
        \item Morphological "closing" to minimize transpiration and gas intake.
      \end{itemize}
    \end{column}
    \begin{column}{0.48\textwidth}
      \textbf{\textcolor{blue}{Bromeliaceae (Dissipative Strategy)}}
      \begin{itemize}
        \item SD Increase: Up to $25.0$ n/$mm^2$.
        \item Active thermoregulation via evaporative cooling.
      \end{itemize}
    \end{column}
  \end{columns}
\end{frame}

