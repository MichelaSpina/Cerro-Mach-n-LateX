% SLIDE 3: CERRO MACHÍN VOLCANO LOCATION
\begin{frame}{Cerro Machín Volcano (CMV)}
  \begin{columns}[T]
    \begin{column}{0.6\textwidth}
      \begin{itemize}
        \item \textbf{Location}: Eastern flank of the Cordillera Central, 17 km west of Ibagué.
        \item \textbf{Structure}: Volcanic complex covering 13 $km^2$ with a 2.4 km diameter crater.
        \item \textbf{Tectonics}: Located at the intersection of the Cajamarca (NE) and Salento (NW) faults.
        \item \textbf{Current Status}: Quiescent phase characterized by persistent hydrothermal degassing.
      \end{itemize}
    \end{column}
    
    \begin{column}{0.35\textwidth}
