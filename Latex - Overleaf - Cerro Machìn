% SLIDE 6: METODOLOGIA E CAMPIONAMENTO
\begin{frame}{Metodologia e Strategia di Campionamento}
  \begin{itemize}
    \item \textbf{Gradienti}: Dal bosco chiuso (T2) ai campi fumarolici attivi (P2) \cite{186}.
    \item \textbf{Tecniche}: 
      \begin{itemize}
        \item \textbf{Telerilevamento}: Sentinel-2 (NDVI, GCI, EVI) \cite{352, 358}.
        \item \textbf{Field data}: Flussi $CO_2$ (metodo camera chiusa), $T_{soil}$, XRF per suoli \cite{280, 282, 330}.
        \item \textbf{Analisi tratti}: Densità stomatica (SD) e dei tricomi tramite impressioni epidermiche \cite{303, 320}.
      \end{itemize}
  \end{itemize}
\end{frame}

% SLIDE 7: RISULTATI - GRADIENTI ABIOTICI
\begin{frame}{Risultati: Stress Termico e Geochimico}
  \begin{itemize}
    \item \textbf{Temperatura suolo}: Picco a T1 ($41.8^\circ$C) superiore ai siti fumarolici attivi (P2: $36.5^\circ$C) \cite{396, 397}.
    \item \textbf{Flusso $CO_2$}: T1 registra $463.5$ g $m^{-2}$ $d^{-1}$, superando di ordini di grandezza i livelli di fondo globali \cite{405, 407, 408}.
    \item \textbf{Matrice del suolo}: T1 funge da isolante intrappolando fluidi idrotermali, a differenza della matrice rocciosa di P2 \cite{414, 415}.
  \end{itemize}
\end{frame}

% SLIDE 8: RISULTATI - PLASTICITÀ STOMATICA
\begin{frame}{Risultati: Polarizzazione delle Strategie Adattative}
  \begin{columns}[T]
    \begin{column}{0.48\textwidth}
      \textbf{\textcolor{red}{Orchidaceae (Avoidance)}}
      \begin{itemize}
        \item Riduzione drastica SD: $97.2 \rightarrow 48.7$ n/$mm^2$ \cite{520}.
        \item Strategia conservativa per minimizzare perdita d'acqua e uptake di gas tossici \cite{715}.
      \end{itemize}
      \centering
      \includegraphics[width=0.8\textwidth]{orchidaceae_SD.png}
    \end{column}
    \begin{column}{0.48\textwidth}
      \textbf{\textcolor{blue}{Bromeliaceae (Dissipative)}}
      \begin{itemize}
        \item Aumento SD: fino a $25.0$ n/$mm^2$ \cite{540, 716}.
        \item \textbf{Evaporative cooling} per proteggere i tessuti fogliari dal calore radiante del suolo \cite{717}.
      \end{itemize}
      \centering
      \includegraphics[width=0.8\textwidth]{bromeliaceae_SD.png}
    \end{column}
  \end{columns}
\end{frame}

% SLIDE 9: RISULTATI - METALLI E MULTICOLLINEARITÀ
\begin{frame}{Risultati: Il "Pacchetto Geochimico"}
  \begin{itemize}
    \item \textbf{Multicollinearità elevata} ($r > 0.80$): Temperatura, altitudine e metalli sono altamente sincronizzati \cite{381, 725, 726}.
    \item I metalli pesanti agiscono come un \textbf{complesso sincronizzato} piuttosto che variabili indipendenti \cite{626}.
    \item I tratti funzionali epifitici emergono come efficaci \textbf{proxy biologici} dell'attività idrotermale locale \cite{727}.
  \end{itemize}
  \centering
  \includegraphics[width=0.55\textwidth]{regression_metals.png}
\end{frame}

% SLIDE 10: DISCUSSIONE - PROFILO NDVI (FIG. 7)
\begin{frame}{Discussione: Threshold Effect e Vigor Vegetativo}
  \begin{columns}[T]
    \begin{column}{0.5\textwidth}
      \includegraphics[width=\textwidth]{ndvi_transect.jpg}
      \\ {\tiny \textit{Figura 7: Profilo NDVI attraverso il cratere \cite{517}}}
    \end{column}
    \begin{column}{0.45\textwidth}
      \begin{itemize}
        \item \textbf{Declino della produttività}: Non dove il suolo è più caldo (T1), ma dove il degassamento è diretto (P2) \cite{699, 700}.
        \item \textbf{Threshold effect}: Le comunità vegetali mostrano resilienza al calore edafico, ma soccombono allo stress chimico delle fumarole \cite{700, 720}.
        \item \textbf{Collasso clorofilliano}: GCI (-0.028) conferma il danno fisiologico da fumigazione \cite{720}.
      \end{itemize}
    \end{column}
  \end{columns}
\end{frame}

% SLIDE 11: CONCLUSIONI - UN LABORATORIO NATURALE
\begin{frame}{Conclusioni: Persistenza in Ambienti Estremi}
  \begin{itemize}
    \item Il cratere è un'\textbf{interfaccia ad alta entropia} definita dalla geometria delle anomalie idrotermali \cite{711, 712}.
    \item La persistenza biologica è mediata da meccanismi evolutivi contrastanti: \textbf{evitamento morfologico} vs \textbf{dissipazione termica attiva} \cite{732}.
    \item \textbf{Futuro}: Necessità di esperimenti controllati per separare meccanicamente tossicità atmosferica e stress termico edafico \cite{730}.
  \end{itemize}
  \begin{block}{Messaggio Finale}
    Il Cerro Machín è un laboratorio unico per esplorare i limiti e le strategie adattative della vita in ambienti dominati da forzanti geofisiche \cite{731, 732}.
  \end{block}
\end{frame}

