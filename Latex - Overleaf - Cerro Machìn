% SLIDE 6: MODEL ORGANISMS - ORCHIDACEAE AND BROMELIACEAE
\begin{frame}{Model Organisms: Orchidaceae and Bromeliaceae}
  \begin{itemize}
    \item \textbf{Epiphytic Habit}: The lack of soil connection imposes a condition of \textbf{"intermittent drought"}, effectively forcing these plants to function as xerophytes.
  \end{itemize}

  \begin{columns}[T]
    \begin{column}{0.48\textwidth}
      \begin{block}{Orchidaceae}
        \begin{itemize}
          \item \textbf{Velamen radicum}: Highly specialized root tissue for rapid water absorption and retention.
          \item \textbf{Xerophytic Traits}: Presence of pseudobulbs and thick cuticles to counteract desiccation.
          \item \textbf{Root Framework}: Support for diverse microbial communities and biological nitrogen fixation.
        \end{itemize}
      \end{block}
    \end{column}

    \begin{column}{0.48\textwidth}
      \begin{block}{Bromeliaceae}
        \begin{itemize}
          \item \textbf{Tank Structures}: Specialized leaf arrangements forming reservoirs for water and nutrients.
          \item \textbf{Environmental Sensitivity}: Strong dependence on stable moisture regimes and microclimatic conditions.
          \item \textbf{Trophic Support}: Providing breeding sites and shelter for associated fauna and microorganisms.
        \end{itemize}
      \end{block}
    \end{column}
  \end{columns}
\end{frame}

