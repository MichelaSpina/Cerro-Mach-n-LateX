% SLIDE 6: METODOLOGIA
\begin{frame}{Metodologia e Strategia di Campionamento}
  \begin{itemize}
    \item \textbf{Gradienti}: Dal bosco chiuso ai campi fumarolici attivi.
    \item \textbf{Field data}: Flussi $CO_2$, $T_{soil}$, XRF per suoli.
    \item \textbf{Analisi tratti}: Densità stomatica (SD) e dei tricomi tramite impressioni epidermiche.
  \end{itemize}
\end{frame}

% SLIDE 7: RISULTATI - PLASTICITÀ STOMATICA
\begin{frame}{Risultati: Polarizzazione delle Strategie Adattative}
  \begin{columns}[T]
    \begin{column}{0.48\textwidth}
      \textbf{\textcolor{red}{Orchidaceae (Avoidance)}}
      \begin{itemize}
        \item Riduzione drastica SD: $97.2 \rightarrow 48.7$ n/$mm^2$.
        \item Strategia conservativa per minimizzare uptake di gas tossici.
      \end{itemize}
    \end{column}
    \begin{column}{0.48\textwidth}
      \textbf{\textcolor{blue}{Bromeliaceae (Dissipative)}}
      \begin{itemize}
        \item Aumento SD: fino a $25.0$ n/$mm^2$.
        \item \textbf{Evaporative cooling} per proteggere i tessuti dal calore radiante.
      \end{itemize}
    \end{column}
  \end{columns}
\end{frame}

