% SLIDE 8: ABIOTIC MONITORING & GEOCHEMISTRY
\begin{frame}{Abiotic Forcing: Geochemical and Thermal Monitoring}
  \begin{columns}[T]
    \begin{column}{0.6\textwidth}
      \begin{itemize}
        \item \textbf{Thermal Profiling}: In situ $T_{soil}$ (0-10 cm) and $T_{env}$ using high-precision digital probes.
        \item \textbf{Diffuse Degassing}: $CO_2$ flux measured via \textbf{static closed-chamber method}.
        \begin{itemize}
            \item Quantification based on the Ideal Gas Law.
            \item Focus on peak geochemical forcing (Site T1).
        \end{itemize}
        \item \textbf{Soil Geochemistry}: XRF analysis for heavy metals and metalloids (As, Hg, Pb, Cr, etc.) after room-temperature stabilization.
      \end{itemize}
    \end{column}
    
    \begin{column}{0.35\textwidth}
      \centering
