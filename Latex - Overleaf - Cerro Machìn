% SLIDE 4: CERRO MACHÍN VOLCANO LOCATION
\begin{frame}{Cerro Machín Volcano (CMV)}
  \begin{columns}[T]
    \begin{column}{0.6\textwidth}
      \begin{itemize}
        \item \textbf{Location}: Eastern flank of the Central Cordillera, 17 km west of Ibagué.
        \item \textbf{Structure}: Volcanic complex covering 13 $km^2$ with a 2.4 km diameter crater.
        \item \textbf{Tectonics}: Located at the intersection of the Cajamarca (NE) and Salento (NW) faults.
        \item \textbf{Current Status}: Quiescent phase characterized by persistent hydrothermal degassing.
      \end{itemize}
    \end{column}
    \begin{column}{0.35\textwidth}
      \centering
      \includegraphics[width=\textwidth]{machin_ingrandimento.png}
    \end{column}
  \end{columns}
\end{frame}

% SLIDE 5: HABITAT AND ECOLOGICAL FRAMEWORK
\begin{frame}{Habitat and Ecological Framework}
  \begin{columns}[T]
    \begin{column}{0.6\textwidth}
      \begin{itemize}
        \item \textbf{The Paradox}: Located in a wet forest (RH 85\%), but functionally \textbf{arid} due to geothermal heat.
        \item \textbf{Synergistic Stressors}:
        \begin{itemize}
            \item \textbf{Epiphytic Habit}: "Intermittent drought".
            \item \textbf{Fumarolic Activity}: High Vapor Pressure Deficit (VPD).
        \end{itemize}
      \end{itemize}
      \vspace{0.3cm}
      \begin{alertblock}{The Environmental Sieve}
        Volcanic disturbance creates \textbf{primary succession} substrates, imposing severe \textbf{abiotic filters} that select specific life strategies.
      \end{alertblock}
    \end{column}
    \begin{column}{0.35\textwidth}
      \centering
      \includegraphics[width=\textwidth]{fumarole_machin.jpeg} 
      \\ \vspace{2mm}
      {\tiny \textit{The volcano as a geo-ecological filter}}
    \end{column}
  \end{columns}
\end{frame}

% SLIDE 6: MODEL ORGANISMS
\begin{frame}{Model Organisms: Orchidaceae and Bromeliaceae}
  \begin{itemize}
    \item \textbf{Epiphytic Habit}: Lack of soil connection forces plants to function as xerophytes.
  \end{itemize}
  \begin{columns}[T]
    \begin{column}{0.48\textwidth}
      \begin{block}{Orchidaceae}
        \begin{itemize}
          \item \textbf{Velamen radicum}: Specialized tissue for water absorption.
          \item \textbf{Xerophytic Traits}: Pseudobulbs and thick cuticles.
        \end{itemize}
      \end{block}
    \end{column}
    \begin{column}{0.48\textwidth}
      \begin{block}{Bromeliaceae}
        \begin{itemize}
          \item \textbf{Sensitivity}: Strong dependence on moisture regimes.
          \item \textbf{Trophic Role}: multiplier of ecosystem health.
        \end{itemize}
      \end{block}
    \end{column}
  \end{columns}
\end{frame}

