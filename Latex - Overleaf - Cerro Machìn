% SLIDE 12: RESULTS - ABIOTIC MONITORING
\begin{frame}{Results: Abiotic Forcing and Monitoring}
  \begin{columns}[T]
    \begin{column}{0.55\textwidth}
      \begin{itemize}
        \item \textbf{Thermal Gradient}: Substrate temperatures peaked at $\mathbf{41.8^\circ C}$ (Site T1).
        \item \textbf{Diffuse Degassing}: Mean $CO_2$ flux at T1 reached $\mathbf{463.5 \ g \ m^{-2} d^{-1}}$, vastly exceeding background levels.
        \item \textbf{Soil Geochemistry}: Synchronization of heavy metal concentrations indicating volcanic forcing.
        \item \textbf{Landscape Fragmentation}: Shannon Diversity Index ($H = 3.055$) calculated on EVI distribution.
      \end{itemize}
    \end{column}
    \begin{column}{0.4\textwidth}
      \centering
      \includegraphics[width=\textwidth]{strumentazione_campo.jpg} 
      \\ \vspace{2mm}
      {\tiny \textit{In situ microclimatic and edaphic data collection}}
    \end{column}
  \end{columns}
\end{frame}

