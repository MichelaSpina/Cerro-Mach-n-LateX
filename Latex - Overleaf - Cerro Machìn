% SLIDE 3: LOCALIZZAZIONE CERRO MACHÍN
\begin{frame}{Cerro Machín Volcano (CMV)}
  \begin{itemize}
    \item \textbf{Ubicazione}: Fianco orientale della Cordigliera Centrale, 17 km a ovest di Ibagué \cite{84}.
    \item \textbf{Struttura}: Complesso vulcanico di 13 $km^2$ con un cratere di 2,4 km di diametro \cite{86}.
    \item \textbf{Tettonica}: Situato all'intersezione delle faglie di Cajamarca (NE) e Salento (NW) \cite{113}.
    \item \textbf{Stato attuale}: Fase quiescente con degassamento idrotermale persistente \cite{122}.
  \end{itemize}
\end{frame}

% SLIDE 4: DOMANDE DI RICERCA
\begin{frame}{Domande di Ricerca}
  \begin{block}{Fundamental Question}
    How does local vegetation respond to the combined thermal and geochemical stresses imposed by active degassing? \cite{76}
  \end{block}
  \begin{itemize}
    \item Possono questi gradienti agire come driver ecologici capaci di modellare l'espressione dei tratti funzionali? \cite{77}
    \item \textbf{Thermal stress}: "Thermal engine" che forza la gestione della domanda evaporativa \cite{79}.
    \item \textbf{Geochemical forcing}: Carico tossicologico (degassamento $CO_2$ e metalli pesanti) \cite{80}.
  \end{itemize}
\end{frame}

